{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RustyGene",
  "version": "0.1.0",
  "identifier": "com.rustygene.app",
  "build": {
    "beforeDevCommand": "npm run dev -- --host",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RustyGene",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$RUSTYGENE_DATA_DIR/**"]
      }
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
